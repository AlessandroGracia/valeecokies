# ============================================
# Configuración del Backend - galletas-system
# ============================================
# Copia este archivo como .env y llena con tus valores reales
# NUNCA subas el archivo .env al repositorio
# ============================================

# Base de datos PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:TU_PASSWORD_AQUI@db.TU_PROJECT.supabase.co:5432/postgres

# Supabase API
SUPABASE_URL=https://TU_PROJECT.supabase.co
SUPABASE_KEY=tu_anon_public_key_aqui

# Seguridad JWT - Genera una key segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_key_por_una_segura_generada

# Modo debug (True en desarrollo, False en producción)
DEBUG=True
